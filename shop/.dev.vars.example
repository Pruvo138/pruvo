# Yerel gelistirme / sandbox anahtarlari SABLONU.
# GERCEK degerleri bu dosyaya DEGIL, ayni dizindeki .dev.vars'a yaz (.dev.vars gitignore'da).
# Sandbox hesabi: https://sandbox-merchant.iyzipay.com (ucretsiz) -> Ayarlar > API Anahtarlari.
IYZICO_API_KEY = "sandbox-XXXX"
IYZICO_SECRET_KEY = "sandbox-XXXX"
# Bos birakilirsa bildirim atlanir (odeme akisini ASLA bloklamaz):
TELEGRAM_TOKEN = ""
# Havale/EFT (paket-shop-kargo.md kalem 6): gercek IBAN + unvan wrangler.toml [vars]'ta
# (sir degil — musteriye gosterilir). Yerel testte farkli deger gerekiyorsa burada ez;
# env tanimsiz kalirsa uc 503 'havale-hazir-degil' doner (secenek musteriye kapanir).
# HAVALE_IBAN = ""
# HAVALE_UNVAN = ""

# --- Siparis yonetimi paketi (tools/paket-siparis-yonetimi.md) ---
# Yonetim sayfasi anahtari: tanimli DEGILSE tum /api/shop/yonet* 404 (ozellik kapali).
# Canliya: openssl rand -hex 24 -> wrangler secret put YONET_ANAHTAR
YONET_ANAHTAR = ""
# Resend e-posta anahtari: tanimli degilse e-posta atlanir + Telegram uyarisi (siparis akisi
# BOZULMAZ). Canliya: wrangler secret put RESEND_API_KEY
RESEND_API_KEY = ""
# Parametrik STL uretimi: shop -> onizleme /ic-derle icin PAYLASILAN anahtar (ayni deger
# onizleme worker'inda da secret olarak durur). Tanimsizsa ic uc 404 (parametrik STL kapali).
IC_DERLE_ANAHTAR = ""
